# Copy to .env.local and fill in real values. Never commit .env.local.
# Restart `npm run dev` after changing this file.

# Personal API token — no "Bearer" prefix, no quotes around the value
# Admin → Connections → Personal API token, or Developers → My Access Tokens
MONDAY_API_KEY=eyJhbGciOiJIUzI1NiJ9.eyJ0aWQiOjY2MDIxODQ4NCwiYWFpIjoxMSwidWlkIjoxMDM4MDg3NjksImlhZCI6IjIwMjYtMDUtMTlUMDk6MDg6NTAuMDAwWiIsInBlciI6Im1lOndyaXRlIiwiYWN0aWQiOjM1MTY3Nzc2LCJyZ24iOiJldWMxIn0.bGITzzikh5q_isuFXWxyf5of727N9ffBu1UZm42YhPQ

# Numeric board ID from the board URL (e.g. https://...monday.com/boards/1234567890)
MONDAY_BOARD_ID=5097679903

# Secret token for /api/monday-webhook?secret=... (Monday.com incoming webhook URL)
MONDAY_WEBHOOK_SECRET=your_monday_webhook_secret_here

# Admin password used for /admin authentication (do not commit real secrets).
ADMIN_PASSWORD=your_admin_password_here

# Public app URL for magic links (production: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP (e.g. Google Workspace App Password for dev@beyondtcode.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dev@beyondtcode.com
SMTP_PASSWORD=your_app_password_here

# Upstash QStash — one delayed message per candidate at scheduled exam time
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key_here

# Monday column IDs are configured in src/lib/monday/columns.ts:
#   examType: color_mm3zj3j9
#   candidateSource: text_mm3zwgfx
#   scheduledAt: date_mm3y4hj6 (placeholder on create, real date on follow-up update)
#   teamEmail: email_mm3zrjey (default office@beyondtcode.com on create)
